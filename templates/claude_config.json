{
  "mcpServers": {
    "code-intel": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "src.cli.main",
        "mcp"
      ],
      "env": {
        "DATABASE_URL": "postgresql+asyncpg://postgres:password@localhost:5432/codeintel",
        "USE_BITEMPORAL": "true"
      }
    }
  }
}
