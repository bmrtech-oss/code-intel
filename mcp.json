{
  "mcpServers": {
    "code-intel": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "code_intel.cli.main",
        "mcp"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL:-postgresql+asyncpg://postgres:password@localhost:5432/codeintel}",
        "REDIS_HOST": "${REDIS_HOST:-localhost}"
      }
    }
  }
}
